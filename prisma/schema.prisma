generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  apiToken      String?   @unique

  // Profile
  currentRole     String?
  yearsExp        String?
  targetRoles     String?
  targetCompanies String?
  skills          String?
  jobSearchStatus String?
  location        String?
  linkedinUrl     String?
  onboarded       Boolean  @default(false)

  // Autofill fields
  phone           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  zipCode         String?
  country         String?
  portfolioUrl    String?
  githubUrl       String?
  pronouns        String?

  // Gmail integration
  gmailAccessToken  String?  @db.Text
  gmailRefreshToken String?  @db.Text
  gmailConnected    Boolean  @default(false)
  gmailLastSync     DateTime?

  accounts      Account[]
  sessions      Session[]
  jobs          Job[]
  gmailSuggestions GmailSuggestion[]
  prepBookmarks PrepBookmark[]
  prepProgress  PrepProgress[]
  interviewDebriefs InterviewDebrief[]
  resumeVersions ResumeVersion[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id          String    @id @default(cuid())
  userId      String
  company     String
  role        String
  status      JobStatus @default(APPLIED)
  location    String?
  salary      String?
  jobUrl      String?
  notes       String?   @db.Text
  appliedDate DateTime  @default(now())
  deadline    DateTime?
  interviewRound String? // e.g. "Round 1 — Recruiter Screen"
  resumeVersionId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]
  timeline Timeline[]
  gmailSuggestions GmailSuggestion[]
  debrief  InterviewDebrief?
  resumeVersion ResumeVersion? @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  jobId     String
  name      String
  role      String?
  email     String?
  phone     String?
  linkedin  String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Timeline {
  id        String   @id @default(cuid())
  jobId     String
  event     String
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  APPLIED
  SCREENING
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

model PrepBookmark {
  id         String   @id @default(cuid())
  userId     String
  role       String
  level      String
  category   String   // questions | coding | system | behavioral
  questionId String
  question   String   @db.Text
  answer     String?  @db.Text
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

model PrepProgress {
  id        String   @id @default(cuid())
  userId    String
  role      String
  level     String
  topic     String
  done      Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, level, topic])
  @@index([userId])
}

model CompanyInsight {
  id              String   @id @default(cuid())
  company         String
  appliedToResponse Int?   // days from applied to first response
  appliedToOffer  Int?     // days from applied to offer
  appliedToReject Int?     // days from applied to rejection
  outcome         String   // RESPONDED | OFFER | REJECTED | GHOSTED
  createdAt       DateTime @default(now())

  @@index([company])
}

model ResumeVersion {
  id          String   @id @default(cuid())
  userId      String
  name        String   // e.g. "React Focused", "Fullstack v2"
  fileUrl     String?  // hosted URL (Supabase or external)
  filePath    String?  // Supabase storage path for deletion
  notes       String?  @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@index([userId])
}

model InterviewDebrief {
  id              String   @id @default(cuid())
  jobId           String   @unique
  userId          String
  technicalQs     String?  @db.Text  // Questions asked
  behavioralQs    String?  @db.Text  // Questions struggled with
  cultureScore    Int?               // 1-5
  interviewerName String?
  interviewDate   DateTime?
  notes           String?  @db.Text
  round           String?            // e.g. "Round 1 - Recruiter Screen"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GmailSuggestion {
  id            String   @id @default(cuid())
  userId        String
  jobId         String?
  emailId       String   @unique
  emailSubject  String
  emailFrom     String
  emailDate     DateTime
  detectedType  String   // INTERVIEW | REJECTION | OFFER | FOLLOWUP
  suggestedStatus String?
  confidence    Int      // 0-100
  snippet       String?  @db.Text
  status        String   @default("PENDING") // PENDING | ACCEPTED | DISMISSED
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
}
